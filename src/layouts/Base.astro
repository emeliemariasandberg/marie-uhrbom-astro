---
import SiteHeader from '@/components/SiteHeader.astro';
import SiteFooter from '@/components/SiteFooter.astro';
import SiteBanner from '@/components/SiteBanner.astro';
import '@/styles/global.css';
import { makeUrlFn } from '@/utils/url';
import seoSettings from '@/content/settings/seo.json';
import banner from '@/content/settings/banner.json';
import contact from '@/content/settings/contact.json';

const siteUrl = makeUrlFn(import.meta.env.BASE_URL);

interface Props {
  title?: string;
  description?: string;
  slug?: string;
}

const {
  title = seoSettings.defaultTitle,
  description = seoSettings.defaultDescription,
  slug = '',
} = Astro.props;

const canonicalUrl = new URL(slug ? `/${slug}` : '/', Astro.site ?? 'https://marieuhrbom.se');
---

<!doctype html>
<html lang="sv">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl.href} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:locale" content="sv_SE" />
    <meta property="og:site_name" content={seoSettings.siteName} />
    {seoSettings.ogImage && (
      <meta property="og:image" content={new URL(seoSettings.ogImage, Astro.site ?? 'https://marieuhrbom.se').href} />
    )}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {seoSettings.ogImage && (
      <meta name="twitter:image" content={new URL(seoSettings.ogImage, Astro.site ?? 'https://marieuhrbom.se').href} />
    )}

    <link rel="icon" type="image/svg+xml" href={siteUrl('/favicon.svg')} />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": ["LocalBusiness", "HealthAndBeautyBusiness"],
          "@id": "https://marieuhrbom.se/#business",
          "name": "Marie Uhrbom",
          "description": seoSettings.defaultDescription,
          "url": "https://marieuhrbom.se",
          "telephone": contact.phone,
          "email": contact.email,
          "address": {
            "@type": "PostalAddress",
            "addressLocality": "Mellerud",
            "addressRegion": "Västra Götaland",
            "addressCountry": "SE"
          },
          "founder": { "@type": "Person", "@id": "https://marieuhrbom.se/#marie", "name": "Marie Uhrbom" },
          "hasOfferCatalog": {
            "@type": "OfferCatalog",
            "itemListElement": [
              { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Klassisk Homeopati", "url": "https://marieuhrbom.se/homeopati" } },
              { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Hälsa & Livscoachning", "url": "https://marieuhrbom.se/vagledning" } },
              { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Läderhantverk", "url": "https://marieuhrbom.se/hantverk" } }
            ]
          }
        },
        {
          "@type": "Person",
          "@id": "https://marieuhrbom.se/#marie",
          "name": "Marie Uhrbom",
          "jobTitle": "Homeopat, Livscoach & Sadelmakare",
          "worksFor": { "@id": "https://marieuhrbom.se/#business" },
          "url": "https://marieuhrbom.se/om-marie"
        }
      ]
    })} />

    <!-- Google Fonts: Cormorant Garamond + Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Inter:wght@400;500;600&display=swap"
    />
  </head>
  <body>
    {banner.enabled && <SiteBanner />}
    <SiteHeader />
    <main id="main-content">
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
