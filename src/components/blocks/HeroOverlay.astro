---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  image?: string;
  alt?: string;
  cta1Label?: string;
  cta1Href?: string;
  cta2Label?: string;
  cta2Href?: string;
}
import { makeUrlFn } from '@/utils/url';
const siteUrl = makeUrlFn(import.meta.env.BASE_URL);
const { eyebrow, title, subtitle, image, alt, cta1Label, cta1Href, cta2Label, cta2Href } = Astro.props;
---

<section class="relative min-h-[70vh] flex items-end overflow-hidden">
  {image && (
    <img
      src={siteUrl(image)}
      alt={alt ?? ''}
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
  )}
  <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-transparent"></div>

  <div class="relative container-prose py-20 text-white">
    {eyebrow && <p class="eyebrow mb-4 text-white/80">{eyebrow}</p>}
    <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-medium leading-[1.1] mb-6 max-w-2xl">
      {title}
    </h1>
    {subtitle && (
      <p class="text-lg text-white/80 leading-relaxed mb-8 max-w-xl">
        {subtitle}
      </p>
    )}
    {(cta1Label || cta2Label) && (
      <div class="flex flex-wrap gap-3">
        {cta1Label && cta1Href && (
          <a
            href={siteUrl(cta1Href)}
            class="inline-flex items-center px-6 py-3 rounded-lg bg-white text-[var(--color-leather-deep)] font-medium text-sm hover:bg-white/90 transition-colors shadow-[var(--shadow-soft)]"
          >
            {cta1Label}
          </a>
        )}
        {cta2Label && cta2Href && (
          <a
            href={siteUrl(cta2Href)}
            class="inline-flex items-center px-6 py-3 rounded-lg border border-white/40 text-white font-medium text-sm hover:bg-white/10 transition-colors"
          >
            {cta2Label}
          </a>
        )}
      </div>
    )}
  </div>
</section>
