---
interface ServiceItem {
  eyebrow?: string;
  title: string;
  body: string;
  linkLabel?: string;
  href?: string;
  size?: 'small' | 'medium' | 'large' | 'wide';
  image?: string;
}
interface Props {
  eyebrow?: string;
  title?: string;
  subtitle?: string;
  items: ServiceItem[];
}
import { makeUrlFn } from '@/utils/url';
const siteUrl = makeUrlFn(import.meta.env.BASE_URL);
const { eyebrow, title, subtitle, items } = Astro.props;
---

<section class="py-16 md:py-20">
  <div class="container-prose">
    {(eyebrow || title || subtitle) && (
      <div class="mb-12 max-w-2xl">
        {eyebrow && <p class="eyebrow mb-3">{eyebrow}</p>}
        {title && <h2 class="font-display text-3xl md:text-4xl font-medium leading-tight mb-4">{title}</h2>}
        {subtitle && <p class="text-[var(--color-muted-foreground)] leading-relaxed">{subtitle}</p>}
      </div>
    )}

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {items.map((item) => {
        const Tag = item.href ? 'a' : 'div';
        const isWide = item.size === 'wide';
        return (
          <Tag
            href={item.href ? siteUrl(item.href) : undefined}
            class:list={[
              'group rounded-2xl border border-[var(--color-border)] bg-[var(--color-card)] overflow-hidden shadow-[var(--shadow-soft)] hover:shadow-[var(--shadow-warm)] transition-shadow',
              isWide
                ? 'lg:col-span-3 flex flex-col lg:flex-row'
                : 'flex flex-col',
              item.size === 'large' && 'lg:col-span-2',
            ]}
          >
            {item.image && (
              <div class:list={[
                'overflow-hidden shrink-0',
                isWide ? 'aspect-video lg:aspect-auto lg:w-2/5' : 'aspect-video',
              ]}>
                <img
                  src={siteUrl(item.image)}
                  alt={item.title}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                  loading="lazy"
                />
              </div>
            )}
            <div class:list={[
              'flex flex-col flex-1 justify-center',
              isWide ? 'p-8' : 'p-6',
            ]}>
              {item.eyebrow && <p class="eyebrow mb-2">{item.eyebrow}</p>}
              <h3 class="font-display text-xl font-medium mb-3">{item.title}</h3>
              <p class="text-sm text-[var(--color-muted-foreground)] leading-relaxed">{item.body}</p>
              {item.linkLabel && (
                <span class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-[var(--color-leather)] group-hover:text-[var(--color-leather-deep)] group-hover:text-base transition-all duration-200">
                  {item.linkLabel}
                  <span aria-hidden="true">→</span>
                </span>
              )}
            </div>
          </Tag>
        );
      })}
    </div>
  </div>
</section>
