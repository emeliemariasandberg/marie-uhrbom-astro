---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  image?: string;
  alt?: string;
  cta1Label?: string;
  cta1Href?: string;
  cta2Label?: string;
  cta2Href?: string;
  footnote?: string;
}
const { eyebrow, title, subtitle, image, alt, cta1Label, cta1Href, cta2Label, cta2Href, footnote } = Astro.props;
---

<section class="py-20 md:py-28">
  <div class="container-prose">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div>
        {eyebrow && <p class="eyebrow mb-4">{eyebrow}</p>}
        <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-medium leading-[1.1] mb-6">
          {title}
        </h1>
        {subtitle && (
          <p class="text-lg text-[var(--color-muted-foreground)] leading-relaxed mb-8 max-w-lg">
            {subtitle}
          </p>
        )}
        {(cta1Label || cta2Label) && (
          <div class="flex flex-wrap gap-3">
            {cta1Label && cta1Href && (
              <a
                href={cta1Href}
                class="inline-flex items-center px-6 py-3 rounded-lg bg-[var(--color-primary)] text-[var(--color-primary-foreground)] font-medium text-sm hover:opacity-90 transition-opacity shadow-[var(--shadow-soft)]"
              >
                {cta1Label}
              </a>
            )}
            {cta2Label && cta2Href && (
              <a
                href={cta2Href}
                class="inline-flex items-center px-6 py-3 rounded-lg border border-[var(--color-border)] text-[var(--color-foreground)] font-medium text-sm hover:bg-[var(--color-secondary)] transition-colors"
              >
                {cta2Label}
              </a>
            )}
          </div>
        )}
        {footnote && (
          <p class="mt-6 text-xs text-[var(--color-muted-foreground)]">{footnote}</p>
        )}
      </div>

      {image && (
        <div class="relative rounded-2xl overflow-hidden aspect-[4/3] lg:aspect-[3/4] shadow-[var(--shadow-warm)]">
          <img
            src={image}
            alt={alt ?? ''}
            class="w-full h-full object-cover"
            loading="eager"
          />
        </div>
      )}
    </div>
  </div>
</section>
