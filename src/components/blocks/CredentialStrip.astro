---
import { makeUrlFn } from '@/utils/url';
const siteUrl = makeUrlFn(import.meta.env.BASE_URL);

interface Credential {
  label: string;
  since: string;
  description?: string;
  href?: string;
}
interface Props {
  items: Credential[];
}
const { items } = Astro.props;
---

<section class="py-10 border-y border-[var(--color-border)] bg-[var(--color-secondary)]/30">
  <div class="container-prose">
    <dl class="grid grid-cols-1 sm:grid-cols-3 gap-8 sm:gap-4 text-center sm:divide-x sm:divide-[var(--color-border)]">
      {items.map((item) => (
        <div class="flex flex-col items-center gap-1 px-4">
          <dt class="eyebrow">{item.label}</dt>
          <dd class="font-display text-3xl font-medium text-[var(--color-leather-deep)]">{item.since}</dd>
          {item.description && (
            <p class="text-xs text-[var(--color-muted-foreground)] mt-0.5">{item.description}</p>
          )}
          {item.href && (
            <a
              href={siteUrl(item.href)}
              class="mt-2 text-xs font-medium text-[var(--color-leather)] hover:text-[var(--color-leather-deep)] transition-colors"
            >
              Läs mer →
            </a>
          )}
        </div>
      ))}
    </dl>
  </div>
</section>
