---
import { marked } from 'marked';
import { makeUrlFn, isExternal } from '@/utils/url';
const siteUrl = makeUrlFn(import.meta.env.BASE_URL);

interface Props {
  eyebrow?: string;
  title: string;
  body: string;
  image?: string;
  alt?: string;
  bgImage?: string;
  linkLabel?: string;
  linkHref?: string;
}
const { eyebrow, title, body, image, alt, bgImage, linkLabel, linkHref } = Astro.props;
const bodyHtml = marked.parse(body);
---

<section class:list={['relative overflow-hidden py-16 md:py-20', !bgImage && 'bg-[var(--color-secondary)]/40']}>
  {bgImage && (
    <>
      <img src={siteUrl(bgImage)} alt="" aria-hidden="true"
        class="absolute inset-0 w-full h-full object-cover -z-10" />
      <div class="absolute inset-0 bg-gradient-to-l from-background via-background/85 to-background/30 -z-10"></div>
    </>
  )}
  <div class="container-prose">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 items-center">
      {image && (
        <div class="lg:col-span-2 relative">
          {bgImage && (
            <div class="absolute -inset-6 rounded-[2rem] bg-[var(--color-leather)]/10 blur-2xl"></div>
          )}
          <div class="relative rounded-2xl overflow-hidden aspect-[3/4] sm:aspect-[4/3] lg:aspect-[3/4] shadow-[var(--shadow-warm)]">
            <img
              src={siteUrl(image)}
              alt={alt ?? ''}
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
        </div>
      )}
      <div class:list={[image ? 'lg:col-span-3' : 'lg:col-span-5']}>
        {eyebrow && <p class="eyebrow mb-4">{eyebrow}</p>}
        <h2 class="font-display text-3xl md:text-4xl font-medium leading-tight mb-6">{title}</h2>
        <div class="prose-warm" set:html={bodyHtml} />
        {linkLabel && linkHref && (
          <a
            href={siteUrl(linkHref)}
            {...(isExternal(linkHref) ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
            class="mt-6 inline-flex items-center gap-1.5 text-sm font-medium text-[var(--color-leather)] hover:text-[var(--color-leather-deep)] transition-colors"
          >
            {linkLabel}
            <span aria-hidden="true">→</span>
          </a>
        )}
      </div>
    </div>
  </div>
</section>
