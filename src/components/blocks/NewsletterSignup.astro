---
interface Props {
  eyebrow?: string;
  title?: string;
  body?: string;
}

const { eyebrow, title, body } = Astro.props;
const formId = `nl-${Math.random().toString(36).slice(2, 7)}`;
---

<section class="py-16 md:py-20 bg-[var(--color-secondary)]">
  <div class="container-prose max-w-xl">
    <div class="text-center mb-8">
      {eyebrow && <p class="eyebrow mb-3">{eyebrow}</p>}
      {title && <h2 class="font-display text-3xl md:text-4xl font-medium leading-tight mb-4">{title}</h2>}
      {body && <p class="text-[var(--color-muted-foreground)] leading-relaxed">{body}</p>}
    </div>

    <form id={formId} class="space-y-5" novalidate>
      <input type="text" name="_honey" class="hidden" tabindex="-1" autocomplete="off" />

      <div>
        <label for={`${formId}-email`} class="block text-sm font-medium mb-1.5">
          E-postadress <span class="text-[var(--color-destructive)]">*</span>
        </label>
        <input
          id={`${formId}-email`}
          name="email"
          type="email"
          required
          autocomplete="email"
          class="w-full px-3.5 py-2.5 rounded-lg border border-[var(--color-input)] bg-[var(--color-card)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-ring)] focus:ring-offset-1 transition-shadow"
        />
      </div>

      <div>
        <p class="text-sm font-medium mb-2.5">
          Jag är intresserad av <span class="text-[var(--color-destructive)]">*</span>
        </p>
        <div class="flex flex-col sm:flex-row gap-3">
          <label class="flex items-center gap-2.5 cursor-pointer">
            <input
              type="checkbox"
              name="interest"
              value="halsa"
              class="w-4 h-4 rounded border-[var(--color-input)] accent-[var(--color-leather)]"
            />
            <span class="text-sm">Homeopati &amp; hälsa</span>
          </label>
          <label class="flex items-center gap-2.5 cursor-pointer">
            <input
              type="checkbox"
              name="interest"
              value="hantverk"
              class="w-4 h-4 rounded border-[var(--color-input)] accent-[var(--color-leather)]"
            />
            <span class="text-sm">Läderhantverk</span>
          </label>
        </div>
        <p id={`${formId}-interest-err`} class="hidden text-xs text-[var(--color-destructive)] mt-1.5">
          Välj minst ett alternativ.
        </p>
      </div>

      <div class="flex items-start gap-3">
        <input
          id={`${formId}-gdpr`}
          name="gdpr"
          type="checkbox"
          required
          class="mt-0.5 rounded border-[var(--color-input)] text-[var(--color-primary)] focus:ring-[var(--color-ring)]"
        />
        <label for={`${formId}-gdpr`} class="text-sm text-[var(--color-muted-foreground)] leading-relaxed">
          Jag godkänner att min e-postadress sparas för att ta emot nyhetsbrev från Marie Uhrbom. Jag kan när som helst avsluta prenumerationen.
          <span class="text-[var(--color-destructive)]"> *</span>
        </label>
      </div>

      <div id={`${formId}-success`} class="hidden rounded-lg bg-green-50 border border-green-200 p-4 text-sm text-green-800">
        Tack! Du är nu anmäld. Välkommen till nyhetsbrevet.
      </div>
      <div id={`${formId}-error`} class="hidden rounded-lg bg-red-50 border border-red-200 p-4 text-sm text-red-800">
        Något gick fel. Försök igen eller kontakta mig direkt på marie@marieuhrbom.se.
      </div>

      <button
        type="submit"
        id={`${formId}-submit`}
        class="inline-flex items-center gap-2 px-8 py-3 rounded-lg bg-[var(--color-primary)] text-[var(--color-primary-foreground)] font-medium text-sm hover:opacity-90 transition-opacity disabled:opacity-60 disabled:cursor-not-allowed shadow-[var(--shadow-soft)]"
      >
        <span id={`${formId}-submit-text`}>Prenumerera</span>
        <svg id={`${formId}-spinner`} class="hidden animate-spin" width="16" height="16" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
        </svg>
      </button>
    </form>
  </div>
</section>

<script define:vars={{ formId }}>
  const form = document.getElementById(formId);
  if (!form) return;

  form.addEventListener('submit', async e => {
    e.preventDefault();

    const honey = form.querySelector('[name="_honey"]');
    if (honey && honey.value) return;

    const email   = form.querySelector('[name="email"]').value.trim();
    const gdpr    = form.querySelector('[name="gdpr"]').checked;
    const checks  = [...form.querySelectorAll('[name="interest"]:checked')];
    const interestErr = document.getElementById(`${formId}-interest-err`);
    const successMsg  = document.getElementById(`${formId}-success`);
    const errorMsg    = document.getElementById(`${formId}-error`);
    const submitBtn   = document.getElementById(`${formId}-submit`);
    const spinner     = document.getElementById(`${formId}-spinner`);

    interestErr.classList.add('hidden');
    successMsg.classList.add('hidden');
    errorMsg.classList.add('hidden');

    if (!checks.length) {
      interestErr.classList.remove('hidden');
      return;
    }
    if (!email || !gdpr) return;

    submitBtn.disabled = true;
    spinner.classList.remove('hidden');

    try {
      const data = new FormData();
      data.append('email', email);
      data.append('interest', checks.map(c => c.value).join(','));
      data.append('gdpr', '1');

      const res = await fetch('/newsletter.php', { method: 'POST', body: data });
      if (res.ok) {
        successMsg.classList.remove('hidden');
        form.reset();
      } else {
        throw new Error();
      }
    } catch {
      errorMsg.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      spinner.classList.add('hidden');
    }
  });
</script>
