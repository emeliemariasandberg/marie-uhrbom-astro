---
import { marked } from 'marked';
import { makeUrlFn } from '@/utils/url';
const siteUrl = makeUrlFn(import.meta.env.BASE_URL);

interface Props {
  eyebrow?: string;
  title: string;
  body: string;
  image?: string;
  alt?: string;
}
const { eyebrow, title, body, image, alt } = Astro.props;
const bodyHtml = marked.parse(body);
---

<section class="py-16 md:py-20 bg-[var(--color-secondary)]/40">
  <div class="container-prose">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 items-center">
      {image && (
        <div class="lg:col-span-2 rounded-2xl overflow-hidden aspect-[3/4] sm:aspect-[4/3] lg:aspect-[3/4] shadow-[var(--shadow-warm)]">
          <img
            src={siteUrl(image)}
            alt={alt ?? ''}
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
      )}
      <div class:list={[image ? 'lg:col-span-3' : 'lg:col-span-5']}>
        {eyebrow && <p class="eyebrow mb-4">{eyebrow}</p>}
        <h2 class="font-display text-3xl md:text-4xl font-medium leading-tight mb-6">{title}</h2>
        <div class="prose-warm" set:html={bodyHtml} />
      </div>
    </div>
  </div>
</section>
