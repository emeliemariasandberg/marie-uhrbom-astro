---
interface CardItem {
  icon?: 'info' | 'sparkles' | 'shield';
  title: string;
  body: string;
}
interface Props {
  items: CardItem[];
  columns?: 2 | 3;
}
const { items, columns = 3 } = Astro.props;
---

<section class="py-16 md:py-20">
  <div class="container-prose">
    <div class:list={[
      'grid grid-cols-1 gap-6',
      columns === 2 ? 'sm:grid-cols-2' : 'sm:grid-cols-2 lg:grid-cols-3'
    ]}>
      {items.map((item) => (
        <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-card)] p-6 shadow-[var(--shadow-soft)]">
          <div class="mb-4 w-10 h-10 rounded-full bg-[var(--color-secondary)] flex items-center justify-center text-[var(--color-leather)]">
            {item.icon === 'sparkles' && (
              <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/>
                <path d="M18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456z"/>
              </svg>
            )}
            {item.icon === 'shield' && (
              <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/>
              </svg>
            )}
            {(!item.icon || item.icon === 'info') && (
              <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z"/>
              </svg>
            )}
          </div>
          <h3 class="font-display text-xl font-medium mb-3">{item.title}</h3>
          <p class="text-sm text-[var(--color-muted-foreground)] leading-relaxed">{item.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
