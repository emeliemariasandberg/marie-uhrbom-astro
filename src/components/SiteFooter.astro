---
import navigation from '@/content/settings/navigation.json';
import contact from '@/content/settings/contact.json';
import { makeUrlFn } from '@/utils/url';

const siteUrl = makeUrlFn(import.meta.env.BASE_URL);
---

<footer class="mt-32 border-t border-[var(--color-border)] bg-[var(--color-secondary)]/40">
  <div class="container-prose py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10 md:gap-8">

      <!-- Brand -->
      <div class="md:col-span-2">
        <a href={siteUrl('/')} class="flex items-center gap-1 mb-4" aria-label="Marie Uhrbom — startsida">
          <img src={siteUrl('/logo.svg')} width="56" height="46" alt="" aria-hidden="true" />
          <div>
            <div class="font-display text-lg leading-tight">Marie Uhrbom</div>
            <div class="text-[10px] tracking-[0.22em] uppercase text-[var(--color-muted-foreground)]">
              Hantverk · Homeopati · Hälsa
            </div>
          </div>
        </a>
        <p class="text-sm text-[var(--color-muted-foreground)] max-w-xs leading-relaxed">
          Klassisk homeopati, livscoachning och handgjort läderhantverk.
          Jag tar emot människor och djur — utanför Mellerud, online och via telefon.
        </p>
      </div>

      <!-- Services -->
      <div>
        <h2 class="text-xs font-semibold uppercase tracking-widest text-[var(--color-foreground)] mb-4">Verksamhet</h2>
        <ul class="space-y-2">
          {navigation.footer.map((item) => (
            <li>
              <a href={siteUrl(item.href)} class="text-sm text-[var(--color-muted-foreground)] hover:text-[var(--color-foreground)] transition-colors">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h2 class="text-xs font-semibold uppercase tracking-widest text-[var(--color-foreground)] mb-4">Kontakt</h2>
        <ul class="space-y-2">
          {contact.email && (
            <li>
              <a href={`mailto:${contact.email}`} class="text-sm text-[var(--color-muted-foreground)] hover:text-[var(--color-foreground)] transition-colors break-all">
                {contact.email}
              </a>
            </li>
          )}
          {contact.phone && (
            <li>
              <a href={`tel:${contact.phone}`} class="text-sm text-[var(--color-muted-foreground)] hover:text-[var(--color-foreground)] transition-colors">
                {contact.phone}
              </a>
            </li>
          )}
          {contact.location && (
            <li class="text-sm text-[var(--color-muted-foreground)]">{contact.location}</li>
          )}
          <li class="pt-1">
            <a href={siteUrl('/kontakt')} class="text-sm text-[var(--color-leather)] hover:text-[var(--color-leather-deep)] transition-colors font-medium">
              Skicka meddelande →
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-6 border-t border-[var(--color-border)] flex flex-wrap items-center justify-between gap-4 text-xs text-[var(--color-muted-foreground)]">
      <span>© {new Date().getFullYear()} Marie Uhrbom · Tystnadsplikt · Ansvarsförsäkrad via Gjensidige</span>
    </div>
  </div>
</footer>
