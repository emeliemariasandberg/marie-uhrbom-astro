---
interface GalleryImage {
  url: string;
  alt: string;
  motif?: string | string[];
  caption?: string;
  detail?: string;
}
interface Props {
  id?: string;
  eyebrow?: string;
  title?: string;
  images: GalleryImage[];
  columns?: 2 | 3 | 4;
  showCaptions?: boolean;
  showFilters?: boolean;
  filterLabel?: string;
  ctaLabel?: string;
  ctaHref?: string;
}
import { makeUrlFn } from '@/utils/url';
import imageAlts from '@/content/settings/image-alts.json';
const siteUrl = makeUrlFn(import.meta.env.BASE_URL);
const { id, eyebrow, title, images, columns = 3, showCaptions = false, showFilters = false, filterLabel, ctaLabel, ctaHref } = Astro.props;

const getAlt = (img: GalleryImage) =>
  (imageAlts as Record<string, string>)[img.url] || img.alt || '';

const uid = Math.random().toString(36).slice(2, 7);
const colClass =
  columns === 2 ? 'grid-cols-1 sm:grid-cols-2' :
  columns === 4 ? 'grid-cols-2 lg:grid-cols-4' :
                  'grid-cols-2 lg:grid-cols-3';

const slides = images.map(img => ({ src: siteUrl(img.url), alt: getAlt(img) }));

const toArray = (motif?: string | string[]) =>
  !motif ? [] : Array.isArray(motif) ? motif : [motif];

const motifs = showFilters
  ? [...new Set(images.flatMap(img => toArray(img.motif)))]
  : [];
const hasFilters = motifs.length > 0;
---

<section id={id} class="py-16 md:py-20 bg-[var(--color-sage)]/8" aria-label="Produktbilder">
  <div class="container-prose">
    {(eyebrow || title) && (
      <div class="mb-8">
        {eyebrow && <p class="eyebrow mb-3">{eyebrow}</p>}
        {title && <h2 class="font-display text-3xl md:text-4xl font-medium leading-tight">{title}</h2>}
        {ctaLabel && ctaHref && (
          <a
            href={ctaHref}
            class="inline-flex items-center gap-2 mt-5 px-7 py-3 rounded-lg bg-[var(--color-primary)] text-[var(--color-primary-foreground)] font-medium text-sm hover:opacity-90 transition-opacity shadow-[var(--shadow-soft)]"
          >
            {ctaLabel}
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        )}
      </div>
    )}

    {hasFilters && (
      <div class="mb-7">
        {filterLabel && (
          <p class="text-[0.7rem] tracking-[0.18em] uppercase text-[var(--color-muted-foreground)] mb-3 font-normal">
            {filterLabel}
          </p>
        )}
        <div class="flex flex-wrap gap-2">
          <button class="filter-pill active" data-filter="alla" data-group={uid}>
            Alla arbeten
          </button>
          {motifs.map(motif => (
            <button class="filter-pill" data-filter={motif} data-group={uid}>
              {motif}
            </button>
          ))}
        </div>
      </div>
    )}

    <div class:list={['grid gap-3 md:gap-4', colClass]}>
      {images.map((img, i) => (
        <button
          class="group relative block w-full aspect-square overflow-hidden rounded-xl shadow-[var(--shadow-soft)] hover:shadow-[var(--shadow-warm)] transition-shadow cursor-pointer"
          data-gallery={uid}
          data-index={i}
          data-motifs={toArray(img.motif).join(',')}
          aria-label={getAlt(img) || `Bild ${i + 1}`}
        >
          <img
            src={siteUrl(img.url)}
            alt={getAlt(img)}
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
            loading={i === 0 ? 'eager' : 'lazy'}
          />
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/10 transition-colors duration-300" />

          {(img.motif || img.caption || img.detail) && (
            <div class="gal-overlay absolute inset-0 flex flex-col justify-end px-3 py-3 md:px-4 md:py-4 md:opacity-0 md:group-hover:opacity-100 md:transition-opacity md:duration-300 pointer-events-none">
              {toArray(img.motif).length > 0 && (
                <p class="gal-motif-tag">{toArray(img.motif).join(' · ')}</p>
              )}
              <p class="font-display text-[0.9rem] md:text-[1.05rem] font-medium leading-snug text-white mb-0.5">
                {img.caption || getAlt(img)}
              </p>
              {img.detail && (
                <p class="hidden md:block text-[0.72rem] text-white/65 tracking-[0.02em]">{img.detail}</p>
              )}
            </div>
          )}

          {showCaptions && getAlt(img) && !img.caption && !img.motif && (
            <div class="gallery-caption absolute bottom-0 inset-x-0 px-3 py-2 pointer-events-none">
              <p class="text-white text-xs leading-snug line-clamp-2">{getAlt(img)}</p>
            </div>
          )}
        </button>
      ))}
    </div>
  </div>
</section>

<!-- Slideshow -->
<dialog id={`ss-${uid}`} class="gallery-ss" aria-label="Bildspel" aria-modal="true">
  <button class="ss-close" aria-label="Stäng">
    <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
    </svg>
  </button>

  <button class="ss-nav ss-prev" aria-label="Föregående bild">
    <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <path d="M15 18l-6-6 6-6"/>
    </svg>
  </button>

  <div class="ss-stage">
    <img id={`ss-img-${uid}`} class="ss-image" alt="" />
  </div>

  <button class="ss-nav ss-next" aria-label="Nästa bild">
    <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <path d="M9 18l6-6-6-6"/>
    </svg>
  </button>

  <div class="ss-footer">
    <p id={`ss-cap-${uid}`} class="ss-caption"></p>
    <p id={`ss-cnt-${uid}`} class="ss-counter"></p>
  </div>
</dialog>

<style>
  /* Filter pills */
  .filter-pill {
    padding: 5px 15px;
    border-radius: 9999px;
    border: 0.5px solid var(--color-border);
    background: transparent;
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 400;
    color: var(--color-muted-foreground);
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s, background 0.2s;
    letter-spacing: 0.04em;
  }
  .filter-pill:hover {
    border-color: var(--color-leather);
    color: var(--color-leather);
    background: color-mix(in oklab, var(--color-leather) 8%, transparent);
  }
  .filter-pill.active {
    background: var(--color-leather);
    color: var(--color-primary-foreground);
    border-color: var(--color-leather);
  }

  /* Gallery overlay */
  .gal-overlay {
    background: linear-gradient(
      to top,
      oklch(0.22 0.04 40 / 0.9) 0%,
      oklch(0.22 0.04 40 / 0.15) 55%,
      transparent 80%
    );
  }
  .gal-motif-tag {
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 400;
    margin-bottom: 0.3rem;
    color: oklch(0.75 0.1 55);
  }

  /* Caption (legacy showCaptions mode) */
  .gallery-caption {
    background: linear-gradient(to top, rgba(0,0,0,0.72) 0%, rgba(0,0,0,0) 100%);
    padding-top: 1.5rem;
  }

  /* Slideshow dialog */
  .gallery-ss {
    padding: 0;
    background: transparent;
    border: none;
    outline: none;
    width: 100vw;
    height: 100dvh;
    max-width: 100vw;
    max-height: 100dvh;
  }
  .gallery-ss::backdrop {
    background: rgba(0,0,0,0.94);
    backdrop-filter: blur(8px);
  }
  .gallery-ss[open] {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
  }

  .ss-stage {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 0;
    padding: 3rem 0;
  }
  .ss-image {
    display: block;
    max-width: min(80vw, 1100px);
    max-height: 85dvh;
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: 0.75rem;
    box-shadow: 0 24px 80px rgba(0,0,0,0.6);
    transition: opacity 0.2s ease;
  }
  .ss-image.fade { opacity: 0; }

  .ss-nav {
    flex-shrink: 0;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.18);
    color: white;
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
    margin: 0 0.5rem;
  }
  .ss-nav:hover { background: rgba(255,255,255,0.22); }
  .ss-nav:disabled { opacity: 0.2; cursor: default; }

  .ss-close {
    position: fixed;
    top: 1rem;
    right: 1.25rem;
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.2);
    color: white;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    transition: background 0.15s;
  }
  .ss-close:hover { background: rgba(255,255,255,0.25); }

  .ss-footer {
    position: fixed;
    bottom: 1.25rem;
    left: 50%;
    transform: translateX(-50%);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }
  .ss-caption {
    color: rgba(255,255,255,0.7);
    font-size: 0.8125rem;
    max-width: 60ch;
  }
  .ss-counter {
    color: rgba(255,255,255,0.4);
    font-size: 0.75rem;
    letter-spacing: 0.05em;
  }
</style>

<script define:vars={{ uid, slides, hasFilters }}>
  // Slideshow
  const dialog  = document.getElementById('ss-' + uid);
  const ssImg   = document.getElementById('ss-img-' + uid);
  const ssCap   = document.getElementById('ss-cap-' + uid);
  const ssCnt   = document.getElementById('ss-cnt-' + uid);
  const closeBtn = dialog.querySelector('.ss-close');
  const prevBtn = dialog.querySelector('.ss-prev');
  const nextBtn = dialog.querySelector('.ss-next');

  let current = 0;
  let opener  = null;

  function show(idx, animate = false) {
    current = ((idx % slides.length) + slides.length) % slides.length;
    if (animate) {
      ssImg.classList.add('fade');
      setTimeout(() => {
        ssImg.src = slides[current].src;
        ssImg.alt = slides[current].alt;
        ssImg.classList.remove('fade');
      }, 180);
    } else {
      ssImg.src = slides[current].src;
      ssImg.alt = slides[current].alt;
    }
    ssCap.textContent = slides[current].alt || '';
    ssCnt.textContent = `${current + 1} / ${slides.length}`;
    prevBtn.disabled = current === 0;
    nextBtn.disabled = current === slides.length - 1;
  }

  document.querySelectorAll(`[data-gallery="${uid}"]`).forEach(btn => {
    btn.addEventListener('click', () => {
      opener = btn;
      show(Number(btn.dataset.index));
      dialog.showModal();
      closeBtn.focus();
    });
  });

  dialog.addEventListener('close', () => {
    opener?.focus();
    opener = null;
  });

  prevBtn.addEventListener('click', () => show(current - 1, true));
  nextBtn.addEventListener('click', () => show(current + 1, true));
  closeBtn.addEventListener('click', () => dialog.close());
  dialog.addEventListener('click', e => { if (e.target === dialog) dialog.close(); });
  dialog.addEventListener('keydown', e => {
    if (e.key === 'ArrowLeft')  show(current - 1, true);
    if (e.key === 'ArrowRight') show(current + 1, true);
    if (e.key === 'Escape')     dialog.close();
  });

  // Motif filter
  if (hasFilters) {
    const pills = document.querySelectorAll(`[data-filter][data-group="${uid}"]`);
    const items = document.querySelectorAll(`[data-gallery="${uid}"]`);

    pills.forEach(pill => {
      pill.addEventListener('click', () => {
        const filter = pill.dataset.filter;
        pills.forEach(p => p.classList.toggle('active', p === pill));
        items.forEach(item => {
          const motifs = (item.dataset.motifs || '').split(',').filter(Boolean);
          item.style.display = (filter === 'alla' || motifs.includes(filter)) ? '' : 'none';
        });
      });
    });
  }
</script>
